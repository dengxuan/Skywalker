    <MicrosoftCodeAnalysisAnalyzersVersion>3.3.4</MicrosoftCodeAnalysisAnalyzersVersion>
    <MicrosoftCodeAnalysisPublicApiAnalyzersVersion>3.3.4</MicrosoftCodeAnalysisPublicApiAnalyzersVersion>
    <MicrosoftSourceLinkVersion>8.0.0</MicrosoftSourceLinkVersion>
  </PropertyGroup>

  <PropertyGroup Label="Build tooling">
    <MinVerPackageVersion>7.0.0</MinVerPackageVersion>
  </PropertyGroup>

  <PropertyGroup Label="System">
    <SystemComponentModelAnnotationsVersion>5.0.0</SystemComponentModelAnnotationsVersion>
    <SystemCollectionsImmutableVersion>8.0.0</SystemCollectionsImmutableVersion>
