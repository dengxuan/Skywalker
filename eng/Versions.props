    <RabbitMQClientVersion>6.8.1</RabbitMQClientVersion>
    <RazorLightVersion>2.3.1</RazorLightVersion>
    <ScribanVersion>7.0.3</ScribanVersion>
    <ScrutorVersion>5.0.1</ScrutorVersion>
