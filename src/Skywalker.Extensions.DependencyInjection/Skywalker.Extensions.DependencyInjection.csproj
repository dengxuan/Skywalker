<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace></RootNamespace>
		<Description>Skywalker 依赖注入抽象，包含自动注册标记接口和特性</Description>
		<SkipAutoAnalyzers>true</SkipAutoAnalyzers>
	</PropertyGroup>

	<!--
		Source Generator 引用：
		- OutputItemType="Analyzer" : 本地开发时作为分析器工作
		- PackAsAnalyzer="true" : 发 NuGet 包时自动放到 analyzers/dotnet/cs 目录
	-->
	<ItemGroup>
		<ProjectReference Include="$(LibrariesProjectRoot)Skywalker.Extensions.DependencyInjection.SourceGenerators\Skywalker.Extensions.DependencyInjection.SourceGenerators.csproj"
						  ReferenceOutputAssembly="false"
						  OutputItemType="Analyzer"
						  PackAsAnalyzer="true" />
	</ItemGroup>

</Project>
